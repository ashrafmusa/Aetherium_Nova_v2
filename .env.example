# Aetherium Nova — Environment Configuration
# Copy this file to .env (for backend) or .env.local (for explorer)
# and fill in your own values. NEVER commit actual secrets.

# ============================================================
# BACKEND (src/node.ts) — rename this to .env
# ============================================================

# API key required for all REST API requests (choose a strong random string)
API_KEY=your-api-key-here

# TCP port for the HTTP REST API (default: 3001)
PORT=3001

# WebSocket port for P2P connections (default: 6001)
P2P_PORT=6001

# Comma-separated list of known peer websocket URLs to connect to on startup
# PEERS=ws://seed1.aetherium-nova.io:6001,ws://seed2.aetherium-nova.io:6001

# ============================================================
# EXPLORER (aetherium-nova-explorer/) — rename this to .env.local
# ============================================================

# URL of the running backend node API
VITE_API_URL=http://localhost:3001

# API key matching the backend API_KEY above
VITE_API_KEY=your-api-key-here
